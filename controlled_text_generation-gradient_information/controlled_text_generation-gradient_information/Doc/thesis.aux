\@writefile{toc}{\contentsline {section}{\numberline {5.6}Why the Gradient Fails, Part One: The Linearization Radius}{41}{section.5.6}\protected@file@percent }
\newlabel{sec:results-linradius}{{5.6}{41}{Why the Gradient Fails, Part One: The Linearization Radius}{section.5.6}{}}
\citation{vaswani2017attention}
\@writefile{lof}{\contentsline {figure}{\numberline {5.4}{\ignorespaces The first-order Taylor surrogate used by the discrete proposal, plotted against the true change in sequence log-likelihood, for GPT-2 Large, coloured by the embedding distance of the candidate token. The two quantities are uncorrelated (Spearman $\rho = -0.011$), so ranking tokens by the surrogate is equivalent to ranking them at random.}}{42}{figure.caption.8}\protected@file@percent }
\newlabel{fig:lin-scatter}{{5.4}{42}{The first-order Taylor surrogate used by the discrete proposal, plotted against the true change in sequence log-likelihood, for GPT-2 Large, coloured by the embedding distance of the candidate token. The two quantities are uncorrelated (Spearman $\rho = -0.011$), so ranking tokens by the surrogate is equivalent to ranking them at random}{figure.caption.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5.5}{\ignorespaces Correlation between the gradient surrogate and the true energy change as a function of the embedding distance of the candidate token, for GPT-2 Large. The correlation decays to zero well within the mean inter-token distance (dashed line), so at the distances of any admissible token substitution the surrogate is uninformative. We note that the correlation is low across the whole admissible range rather than high up to a sharp radius and then falling; the term ``linearization radius'' is a summary of this decay, not a claim of a clean threshold.}}{43}{figure.caption.9}\protected@file@percent }
\newlabel{fig:lin-radius}{{5.5}{43}{Correlation between the gradient surrogate and the true energy change as a function of the embedding distance of the candidate token, for GPT-2 Large. The correlation decays to zero well within the mean inter-token distance (dashed line), so at the distances of any admissible token substitution the surrogate is uninformative. We note that the correlation is low across the whole admissible range rather than high up to a sharp radius and then falling; the term ``linearization radius'' is a summary of this decay, not a claim of a clean threshold}{figure.caption.9}{}}
\citation{holtzman2020curious}
