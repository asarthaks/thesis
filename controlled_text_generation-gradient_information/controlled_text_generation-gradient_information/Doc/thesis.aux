\@writefile{lot}{\contentsline {table}{\numberline {5.8}{\ignorespaces Native diffusion recovery of one flipped token on the reference sequence set, against autoregressive reference rows on the identical task. The diffusion KL sits well below the untouched corruption and the Langevin configurations. The reference rows are for placement only; scale and training domain differ, so the comparison is qualitative.}}{65}{table.caption.19}\protected@file@percent }
\newlabel{tab:diffusion-recovery}{{5.8}{65}{Native diffusion recovery of one flipped token on the reference sequence set, against autoregressive reference rows on the identical task. The diffusion KL sits well below the untouched corruption and the Langevin configurations. The reference rows are for placement only; scale and training domain differ, so the comparison is qualitative}{table.caption.19}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5.9}{\ignorespaces The hybrid sampler, which changes only the proposal direction inside the thesis's exact-energy Metropolis chain on the reference sequence set. Replacing the autoregressive left-context proposal ($23.5\%$ exact) or the gradient arm ($0.0\%$) with the diffusion model's bidirectional one-pass preference lifts exact recovery to $38.5\%$ to $39.0\%$. This is the sufficiency half of the diagnosis.}}{65}{table.caption.20}\protected@file@percent }
\newlabel{tab:diffusion-hybrid}{{5.9}{65}{The hybrid sampler, which changes only the proposal direction inside the thesis's exact-energy Metropolis chain on the reference sequence set. Replacing the autoregressive left-context proposal ($23.5\%$ exact) or the gradient arm ($0.0\%$) with the diffusion model's bidirectional one-pass preference lifts exact recovery to $38.5\%$ to $39.0\%$. This is the sufficiency half of the diagnosis}{table.caption.20}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.13.4}Trained guidance: steering with a noisy-state classifier}{66}{subsection.5.13.4}\protected@file@percent }
\newlabel{sec:results-diffusion-guided}{{5.13.4}{66}{Trained guidance: steering with a noisy-state classifier}{subsection.5.13.4}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5.10}{\ignorespaces Classifier-guided diffusion generation on the continuation task, scored by the independent frozen-model judge (never by the guiding classifier). The guidance moves the guiding classifier's own verdict for both labels (self gain), and moves the independent judge significantly in the negative direction (confidence interval excludes zero at $\gamma \ge 2$) but not the positive direction. The asymmetry tracks the off-manifold disagreement between the two classifiers and a fluency cost, in per-token negative log-likelihood, that grows with the guidance strength.}}{66}{table.caption.21}\protected@file@percent }
\newlabel{tab:diffusion-guided}{{5.10}{66}{Classifier-guided diffusion generation on the continuation task, scored by the independent frozen-model judge (never by the guiding classifier). The guidance moves the guiding classifier's own verdict for both labels (self gain), and moves the independent judge significantly in the negative direction (confidence interval excludes zero at $\gamma \ge 2$) but not the positive direction. The asymmetry tracks the off-manifold disagreement between the two classifiers and a fluency cost, in per-token negative log-likelihood, that grows with the guidance strength}{table.caption.21}{}}
