\@writefile{toc}{\contentsline {section}{\numberline {5.12}The Last-Token Analysis}{60}{section.5.12}\protected@file@percent }
\newlabel{sec:results-lasttoken}{{5.12}{60}{The Last-Token Analysis}{section.5.12}{}}
\citation{vincent2011connection}
\citation{lou2024discrete}
\@writefile{lot}{\contentsline {table}{\numberline {5.6}{\ignorespaces The last-token experiment, $n=200$ sequences per condition. The three columns differ only in the number of downstream scored terms the masked token's input embedding can influence. The language-model gradient norm the discrete sampler consumes rises from an exact zero at the final position to a large value in the interior, yet the gradient-guided arms recover the target token in $0.0\%$ of cases at every position, indistinguishable from a random direction, while the energy-only methods, which never differentiate the energy, recover between $18\%$ and $55\%$. The independence sampler's $100\%$ acceptance at the final position certifies that the implemented energy is exactly the sequence log-likelihood.}}{62}{table.caption.16}\protected@file@percent }
\newlabel{tab:lasttoken}{{5.6}{62}{The last-token experiment, $n=200$ sequences per condition. The three columns differ only in the number of downstream scored terms the masked token's input embedding can influence. The language-model gradient norm the discrete sampler consumes rises from an exact zero at the final position to a large value in the interior, yet the gradient-guided arms recover the target token in $0.0\%$ of cases at every position, indistinguishable from a random direction, while the energy-only methods, which never differentiate the energy, recover between $18\%$ and $55\%$. The independence sampler's $100\%$ acceptance at the final position certifies that the implemented energy is exactly the sequence log-likelihood}{table.caption.16}{}}
