\@writefile{toc}{\contentsline {subsection}{\numberline {5.13.4}Trained guidance: steering with a noisy-state classifier}{66}{subsection.5.13.4}\protected@file@percent }
\newlabel{sec:results-diffusion-guided}{{5.13.4}{66}{Trained guidance: steering with a noisy-state classifier}{subsection.5.13.4}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5.10}{\ignorespaces Classifier-guided diffusion generation on the \emph  {off-domain} continuation task, scored by the independent frozen-model judge (never by the guiding classifier). The guidance moves the guiding classifier's own verdict for both labels (self gain), and moves the independent judge significantly in the negative direction (confidence interval excludes zero at $\gamma \ge 2$) but not the positive direction. The asymmetry tracks the off-manifold disagreement between the two classifiers and a fluency cost, in per-token negative log-likelihood, that grows with the guidance strength. The on-domain trust-region control of Table~\ref {tab:gprime} removes the fluency cost and flips the working direction.}}{67}{table.caption.21}\protected@file@percent }
\newlabel{tab:diffusion-guided}{{5.10}{67}{Classifier-guided diffusion generation on the \emph {off-domain} continuation task, scored by the independent frozen-model judge (never by the guiding classifier). The guidance moves the guiding classifier's own verdict for both labels (self gain), and moves the independent judge significantly in the negative direction (confidence interval excludes zero at $\gamma \ge 2$) but not the positive direction. The asymmetry tracks the off-manifold disagreement between the two classifiers and a fluency cost, in per-token negative log-likelihood, that grows with the guidance strength. The on-domain trust-region control of Table~\ref {tab:gprime} removes the fluency cost and flips the working direction}{table.caption.21}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.13.5}On-domain guidance under a fluency trust region}{67}{subsection.5.13.5}\protected@file@percent }
\newlabel{sec:results-diffusion-gprime}{{5.13.5}{67}{On-domain guidance under a fluency trust region}{subsection.5.13.5}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5.11}{\ignorespaces On-domain, trust-region guided diffusion generation on held-out SST-2 prompts ($n=300$ pairs per cell), scored by the independent judge. Guided target-hit percentage against the paired unguided baseline, with a paired bootstrap $95\%$ confidence interval; the self gain is the guiding classifier's own verdict; the last column is the span negative log-likelihood before and after guidance. The trust region keeps fluency at or below the unguided level, and the judge gain is positive with an interval excluding zero for the positive target at both strengths but null for the negative target. Compare the off-domain run of Table~\ref {tab:diffusion-guided}, where the working direction was the opposite.}}{68}{table.caption.22}\protected@file@percent }
\newlabel{tab:gprime}{{5.11}{68}{On-domain, trust-region guided diffusion generation on held-out SST-2 prompts ($n=300$ pairs per cell), scored by the independent judge. Guided target-hit percentage against the paired unguided baseline, with a paired bootstrap $95\%$ confidence interval; the self gain is the guiding classifier's own verdict; the last column is the span negative log-likelihood before and after guidance. The trust region keeps fluency at or below the unguided level, and the judge gain is positive with an interval excluding zero for the positive target at both strengths but null for the negative target. Compare the off-domain run of Table~\ref {tab:diffusion-guided}, where the working direction was the opposite}{table.caption.22}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5.12}{\ignorespaces Per-class agreement of the guide (noisy classifier) and the independent judge (frozen GPT-2 sentiment head) on the 300 unguided on-domain generations (the neutral calibration surface; guided text is excluded to avoid circularity). The judge confirms the guide's positive verdict 67.9\% of the time ($95$\% CI $[60.4, 75.3]$) and its negative verdict 75.7\% ($[68.5, 82.4]$); the paired difference (positive minus negative) is $-7.7$ points ($[-18.0, 2.6]$). The two conditional agreement rates are statistically indistinguishable (their paired-difference $95$\% CI includes zero), and the point estimates do not favour the positive channel. So the residual disagreement confirms that the two independently trained instruments are only partially aligned ($71.7$\% agreement, up from $56$--$64$\% off-domain), but this table does not identify a by-class asymmetry that would by itself explain why positive steering transferred to the judge and negative steering did not; that transfer asymmetry is reported as observed and setting-contingent, and no class-level mechanism is claimed beyond the overall alignment gap. Overall agreement 71.7\% $[66.3, 76.7]$.}}{70}{table.caption.23}\protected@file@percent }
\newlabel{tab:confusion}{{5.12}{70}{Per-class agreement of the guide (noisy classifier) and the independent judge (frozen GPT-2 sentiment head) on the 300 unguided on-domain generations (the neutral calibration surface; guided text is excluded to avoid circularity). The judge confirms the guide's positive verdict 67.9\% of the time ($95$\% CI $[60.4, 75.3]$) and its negative verdict 75.7\% ($[68.5, 82.4]$); the paired difference (positive minus negative) is $-7.7$ points ($[-18.0, 2.6]$). The two conditional agreement rates are statistically indistinguishable (their paired-difference $95$\% CI includes zero), and the point estimates do not favour the positive channel. So the residual disagreement confirms that the two independently trained instruments are only partially aligned ($71.7$\% agreement, up from $56$--$64$\% off-domain), but this table does not identify a by-class asymmetry that would by itself explain why positive steering transferred to the judge and negative steering did not; that transfer asymmetry is reported as observed and setting-contingent, and no class-level mechanism is claimed beyond the overall alignment gap. Overall agreement 71.7\% $[66.3, 76.7]$}{table.caption.23}{}}
