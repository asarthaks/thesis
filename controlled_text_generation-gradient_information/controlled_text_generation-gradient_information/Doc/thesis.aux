\newlabel{sec:results-diffusion-lin}{{5.13.1}{63}{The signal: linearization on the unified corpus}{subsection.5.13.1}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5.7}{\ignorespaces Linearization correlation between the cheap one-pass surrogate and the expensive per-candidate truth, on the unified WikiText-2 sequence set ($n=200$, four hundred thousand candidate pairs). The autoregressive gradient is statistically zero at every embedding distance; the diffusion score is clearly positive in every stratum at both scales. This is the signal-level confirmation of the training-objective diagnosis.}}{64}{table.caption.18}\protected@file@percent }
\newlabel{tab:diffusion-lin}{{5.7}{64}{Linearization correlation between the cheap one-pass surrogate and the expensive per-candidate truth, on the unified WikiText-2 sequence set ($n=200$, four hundred thousand candidate pairs). The autoregressive gradient is statistically zero at every embedding distance; the diffusion score is clearly positive in every stratum at both scales. This is the signal-level confirmation of the training-objective diagnosis}{table.caption.18}{}}
